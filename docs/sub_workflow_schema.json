{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Minimal GitHub Actions Workflow Schema",
  "type": "object",
  "properties": {
    "on": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } },
        { "type": "object" }
      ]
    },
    "jobs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "runs-on": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "oneOf": [
                {
                  "properties": {
                    "run": { "type": "string" }
                  },
                  "required": ["run"],
                  "additionalProperties": true
                },
                {
                  "properties": {
                    "uses": { "type": "string" }
                  },
                  "required": ["uses"],
                  "additionalProperties": true
                }
              ]
            }
          }
        },
        "required": ["runs-on", "steps"],
        "additionalProperties": true
      }
    }
  },
  "required": ["on", "jobs"],
  "additionalProperties": false
}
